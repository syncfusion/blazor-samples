@page "/ai-smart-rich-text-editor/ai-email-assistant"

@using Syncfusion.Blazor.SmartRichTextEditor
@using Syncfusion.Blazor.RichTextEditor
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs

@*Hidden:Lines*@
@inherits SampleBaseComponent
@*End:Hidden*@

<ActionDescription>
    <p>
        This sample demonstrates the <strong>AI Email Assistant</strong> — an intelligent workspace for composing professional emails. Transform your email writing with instant AI refinements by adjusting tone for different audiences and applying intelligent formatting in real-time.
    </p>
    <ul>
        <li><strong>🎙️ Quick Tone Adjustments:</strong> Apply Professional, Friendly, Formal, Concise, or Empathetic tones to match your audience.</li>
        <li><strong>📧 Email Format:</strong> Convert content into Business, Legal, Journalistic, or Technical styles.</li>
        <li><strong>✏️ Grammar & Spelling:</strong> Automatic review and correction while preserving your original meaning.</li>
    </ul>
    <p>
        <strong>How to use:</strong> Select any text in the editor, press <code>Alt + Enter</code> to open AI Assistant, or use the command menu to apply instant transformations.
    </p>
    <p>
        <strong>Docs &amp; samples:</strong> See the <a href="https://blazor.syncfusion.com/documentation/smart-richtexteditor/getting-started-webapp" target="_blank" aria-label="Navigate to the Syncfusion Smart RichTextEditor Getting Started UG" rel="noopener"><strong>Getting Started guide</strong></a> and the <strong>Smart AI demos</strong> available in your browser for hands-on testing. For developers who want to run these features locally with their own API key, the complete <a href="https://github.com/syncfusion/smart-ai-samples/tree/master/blazor" target="_blank" aria-label="Navigate to the Syncfusion Smart AI Samples GitHub repository" rel="noopener"><strong>Syncfusion Smart AI Samples</strong></a> are available on GitHub.
    </p>
</ActionDescription>

<div class="col-lg-12 control-section" id="email-composition-suite">
    <div class="content-wrapper">
        <div class="email-header">
            <div class="form-group">
                <label>To:</label>
                <SfTextBox Value="john.doe@company.com" />
            </div>
            <div class="form-group">
                <label>Subject:</label>
                <SfTextBox Value="Project Update - Q4 Deliverables" />
            </div>
        </div>
        <SfSmartRichTextEditor Placeholder="Start composing your email...">
            <p>Hi Team,</p> <p>I’m writing to share a concise update on our Q4 deliverables and the next steps to keep momentum.</p>
            <ul> <li><strong>Phase 1:</strong> Completed ahead of schedule; all acceptance criteria have been met.</li> <li><strong>Budget:</strong> Results show a 15% cost reduction compared to initial estimates.</li> <li><strong>Phase 2 Timeline:</strong> Proposed timeline is ready for review. Please check the schedule and highlight any conflicts.</li> <li><strong>Client Feedback:</strong> Initial feedback is positive; the next client review is scheduled for Monday at 10:00 AM.</li> </ul> <p>Action requested: Please review the proposed Phase 2 timeline and reply with any concerns or suggested adjustments by end of day Thursday. If I don’t hear objections, we’ll proceed with the current plan.</p> <p>Thank you for your continued support.</p> <p>Best regards,</p> <p>[Your Name]</p>
            <!-- AI Command Settings -->
            <AssistViewSettings Placeholder="Ask AI to expand, adjust tone, or improve your email..." Commands="@commands">
            </AssistViewSettings>
            <!-- Toolbar Configuration -->
            <RichTextEditorToolbarSettings Items="@ToolbarItems"></RichTextEditorToolbarSettings>
            <!-- Quick Toolbar -->
            <RichTextEditorQuickToolbarSettings Text="@ToolbarItems" />
        </SfSmartRichTextEditor>
    </div>
</div>

@code {
    private List<AICommands> commands = new List<AICommands>
    {
        new AICommands
        {
            Text = "🎙️ Quick Tone Adjustments",
            Items = new List<AICommands>
            {
                new AICommands { Text = "💼 Professional", Prompt = "Rewrite the mail content into a professional, polished business email tone while preserving meaning and key points" },
                new AICommands { Text = "😊 Friendly", Prompt = "Rewrite the mail content in a warm, conversational tone suitable for colleagues, maintaining clarity and intent" },
                new AICommands { Text = "🎩 Formal", Prompt = "Rewrite the mail content in a formal, respectful tone with concise phrasing appropriate for external stakeholders" },
                new AICommands { Text = "⚡ Concise", Prompt = "Shorten the mail content to be direct and to-the-point while keeping essential information and action items" },
                new AICommands { Text = "❤️ Empathetic", Prompt = "Rewrite the mail content with an empathetic, supportive tone that acknowledges concerns and encourages collaboration" },
            }
        },
        new AICommands
        {
            Text = "📧 Email Format",
            Items = new List<AICommands>
            {
                new AICommands { Text = "📈 Business", Prompt = "Convert the mail content into a clear, professional business email style focusing on actions and outcomes" },
                new AICommands { Text = "⚖️ Legal", Prompt = "Convert the mail content into a formal legal style: precise, unambiguous, and factual without adding new claims" },
                new AICommands { Text = "📰 Journalistic", Prompt = "Convert the mail content into a concise journalistic summary: lead with the key point and present facts objectively" },
                new AICommands { Text = "🛠️ Technical", Prompt = "Convert the mail content into a technical email style: use precise terminology, focus on implementation details, assumptions, and next steps." }
            }
        },
        new AICommands { Text = "✏️ Check Grammar & Spelling", Prompt = "Review the mail content for grammar, punctuation, and spelling errors; correct mistakes while preserving original meaning" },
    };
    private List<ToolbarItemModel> ToolbarItems = new List<ToolbarItemModel>()
    {
        new ToolbarItemModel() { Name = "AI Commands" },
        new ToolbarItemModel() { Name = "AI Query" },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.Bold },
        new ToolbarItemModel() { Command = ToolbarCommand.Italic },
        new ToolbarItemModel() { Command = ToolbarCommand.Underline },
        new ToolbarItemModel() { Command = ToolbarCommand.Formats },
        new ToolbarItemModel() { Command = ToolbarCommand.Alignments },
        new ToolbarItemModel() { Command = ToolbarCommand.OrderedList },
        new ToolbarItemModel() { Command = ToolbarCommand.UnorderedList },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateLink },
        new ToolbarItemModel() { Command = ToolbarCommand.Image },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateTable },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.Undo },
        new ToolbarItemModel() { Command = ToolbarCommand.Redo }
    };
}

<style>
    .email-header {
        padding: 20px;
        border-radius: 6px;
        margin-bottom: 20px;
        border: 1px solid #e9ecef;
    }
    
    .form-group {
        display: flex;
        align-items: center;
    }
    
    .form-group label {
        width: 80px;
        font-weight: 600;
    }
</style>