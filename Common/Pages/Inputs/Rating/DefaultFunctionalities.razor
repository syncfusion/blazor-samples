@page "/rating/default-functionalities"
@using Syncfusion.Blazor.Inputs

@*Hidden:Lines*@
@inherits SampleBaseComponent
@*End:Hidden*@

<ActionDescription>
<p>This sample demonstrates the default functionalities of the Rating component. The component allows users to provide a star rating or view other people's ratings on a numeric scale for services such as movies, applications, or products.</p>
    
    <p><b>Key Features Demonstrated:</b></p>
    <p>This example showcases the usage of the following properties in the Blazor Rating component:</p>
    <ul>
        <li><a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Inputs.SfRating.html#Syncfusion_Blazor_Inputs_SfRating_AllowReset" target="_blank" aria-label="AllowReset" rel="noopener">AllowReset</a> - Enable users to reset their rating.</li>
        <li><a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Inputs.SfRating.html#Syncfusion_Blazor_Inputs_SfRating_ReadOnly" target="_blank" aria-label="ReadOnly" rel="noopener">ReadOnly</a> - Display ratings without allowing modification.</li>
        <li><a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Inputs.SfRating.html#Syncfusion_Blazor_Inputs_SfRating_EnableSingleSelection" target="_blank" aria-label="EnableSingleSelection" rel="noopener">EnableSingleSelection</a> - Allow only single rating selection.</li>
        <li><a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Inputs.SfRating.html#Syncfusion_Blazor_Inputs_SfRating_ItemsCount" target="_blank" aria-label="ItemsCount" rel="noopener">ItemsCount</a> - Configure the number of rating items to display.</li>
        <li><a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Inputs.SfRating.html#Syncfusion_Blazor_Inputs_SfRating_Disabled" target="_blank" aria-label="Disabled" rel="noopener">Disabled</a> - Disable the rating component.</li>
    </ul>
</ActionDescription>


<div class="control-section">
    <div class="rating-control">
        <div class="rating-content">
            <label>Basic</label><br/>                         
            <SfRating></SfRating>
        </div>
        <div class="rating-content">
            <label>Reset</label><br/>                       
            <SfRating AllowReset=true Value=3></SfRating>
        </div>
        <div class="rating-content">
            <label>Single Selection</label><br/>                           
            <SfRating Value=3 EnableSingleSelection=true></SfRating>
        </div>
        <div class="rating-content">
            <label>ReadOnly</label><br/>                          
            <SfRating ReadOnly=true Value=3></SfRating>
        </div>
        <div class="rating-content">
            <label>Disabled</label><br/>                         
            <SfRating Disabled=true Value=3></SfRating>
        </div>
        <div class="rating-content">
            <label>Items Count</label><br/>                         
            <SfRating Value=3 ItemsCount=8></SfRating>
        </div>
    </div>
</div>

<style>

    .rating-control .rating-content {
        width: 240px;
        margin: 15px 0;
        min-height: 75px;
        padding:0;
        text-align: center;
    }

    .e-bigger .rating-control .rating-content {
        width: 330px;
        margin: 15px 0;
        min-height: 75px;
        padding:0;
        text-align: center;
    }

    .rating-control{
        margin: 6% auto;
        max-width: 800px;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
    }

</style>


