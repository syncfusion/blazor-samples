    public async Task<List<string>> DiscoverDataSourcesAsync(string endpoint)
    {
        var dataSourceNames = new List<string>();
        // Step 1: Create the XMLA SOAP envelope for DISCOVER_DATASOURCES
        string soapBody = XmlaSoapEnvelope("DISCOVER_DATASOURCES");
        // Step 2: POST the XMLA request
        string xmlResponse = await PostXmlaAsync(endpoint, soapBody);
        // Step 3: Parse the rowset from the XML response
        var rows = ParseRowset(xmlResponse);
        // Step 4: Extract DataSourceName values, filtering out empty/null
        dataSourceNames = rows
                .Where(r => r.ContainsKey("DataSourceName"))
                .Select(r => r["DataSourceName"])
                .Where(name => !string.IsNullOrEmpty(name))
                .ToList();

        return dataSourceNames;
    }

    // Helper: Generate XMLA SOAP envelope
    public static string XmlaSoapEnvelope(string requestType, Dictionary<string, object>? restrictions = null, Dictionary<string, object>? properties = null)
    {
        var sb = new StringBuilder();
        sb.Append(@"<?xml version=""1.0"" encoding=""utf-8""?>");
        sb.Append(@"<soap:Envelope xmlns:soap=""http://schemas.xmlsoap.org/soap/envelope/"">");
        sb.Append("<soap:Header />");
        sb.Append("<soap:Body>");
        sb.Append(@"<Discover xmlns=""urn:schemas-microsoft-com:xml-analysis"">");
        // RequestType
        sb.Append("<RequestType>");
        sb.Append(Escape(requestType));
        sb.Append("</RequestType>");
        // Restrictions
        if (restrictions != null && restrictions.Count > 0)
        {
            sb.Append("<Restrictions><RestrictionList>");
            foreach (var kv in restrictions)
            {
                var key = kv.Key; // assume valid XML name
                var val = ToInvariantString(kv.Value);
                sb.Append('<').Append(key).Append('>')
                  .Append(Escape(val))
                  .Append("</").Append(key).Append('>');
            }
            sb.Append("</RestrictionList></Restrictions>");
        }
        else
        {
            sb.Append("<Restrictions />");
        }
        // Properties
        sb.Append("<Properties><PropertyList>");
        if (properties != null && properties.Count > 0)
        {
            foreach (var kv in properties)
            {
                var key = kv.Key; // assume valid XML name
                var val = ToInvariantString(kv.Value);
                sb.Append('<').Append(key).Append('>')
                  .Append(Escape(val))
                  .Append("</").Append(key).Append('>');
            }
        }
        sb.Append("</PropertyList></Properties>");
        sb.Append("</Discover>");
        sb.Append("</soap:Body>");
        sb.Append("</soap:Envelope>");

        return sb.ToString();
    }

    private static string Escape(string input)
        => input == null ? string.Empty : input;

    private static string ToInvariantString(object value)
        => value == null ? string.Empty : Convert.ToString(value, CultureInfo.InvariantCulture);

    // Helper: POST XMLA request and get response as string
    public static async Task<string> PostXmlaAsync(string endpoint, string bodyXml)
    {
        using var http = new HttpClient();
        var request = new HttpRequestMessage(HttpMethod.Post, endpoint);
        // Accept: text/xml, application/xml, */*;q=0.1
        request.Headers.Accept.Clear();
        request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("text/xml"));
        request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("application/xml"));
        request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("*/*") { Quality = 0.1 });
        // Content-Type: text/xml; charset=utf-8
        request.Content = new StringContent(bodyXml, Encoding.UTF8, "text/xml");
        var response = await http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            throw new HttpRequestException($"HTTP {(int)response.StatusCode}: {response.ReasonPhrase}");
        }
        var text = await response.Content.ReadAsStringAsync();

        return text;
    }

    // Helper: Parse the <row> elements from XMLA rowset response
    public static List<Dictionary<string, string>> ParseRowset(string xmlText)
    {
        if (xmlText == null) throw new ArgumentNullException(nameof(xmlText));
        XDocument doc;
        try
        {
            doc = XDocument.Parse(xmlText, LoadOptions.PreserveWhitespace);
        }
        catch (Exception ex)
        {
            throw new FormatException("Invalid XML content.", ex);
        }
        // Check for SOAP Fault (any namespace)
        var fault = doc
            .Descendants()
            .FirstOrDefault(e => e.Name.LocalName.Equals("Fault", StringComparison.Ordinal));
        if (fault != null)
        {
            var faultText = (fault.Value ?? "SOAP Fault").Trim();
            throw new Exception(string.IsNullOrEmpty(faultText) ? "SOAP Fault" : faultText);
        }
        // Find all <row> elements (any namespace)
        var rows = doc
            .Descendants()
            .Where(e => e.Name.LocalName.Equals("row", StringComparison.Ordinal));

        // For each <row>, collect direct child elements: local name -> trimmed text content
        var result = new List<Dictionary<string, string>>();
        foreach (var row in rows)
        {
            var obj = new Dictionary<string, string>(StringComparer.Ordinal);
            foreach (var child in row.Elements())
            {
                var key = child.Name.LocalName;
                var value = (child.Value ?? string.Empty).Trim();
                obj[key] = value;
            }
            result.Add(obj);
        }

        return result;
    }

