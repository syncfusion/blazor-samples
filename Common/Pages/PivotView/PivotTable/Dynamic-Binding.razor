    public async Task ApplyOlapBindingAsync(string Url, string Catalog,string Cube)
    {
        var url = string.IsNullOrEmpty(Url) ? olapProxyUrl : Url;
        var catalog = string.IsNullOrEmpty(Catalog) ? SelectedCatalog : Catalog;
        var cube = string.IsNullOrEmpty(Cube) ? SelectedCube : Cube;

        if (string.IsNullOrWhiteSpace(url) || string.IsNullOrWhiteSpace(catalog) || string.IsNullOrWhiteSpace(cube))
            return;

        lastRemoteRef = (string.Empty, "");
        // Build OLAP DataSource settings
        ResetPivotSettings(PivotOlapRef, "OLAP");
        OlapUrl = url;
        OlapCatalog = catalog;
        OlapCube = cube;
        shouldAutoConfigRef = true;
    }

