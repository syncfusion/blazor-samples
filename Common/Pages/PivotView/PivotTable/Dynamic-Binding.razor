    // JS: const discoverCatalogs = async (endpoint, _dataSource?) => { ... }
    public static async Task<List<string>> DiscoverCatalogsAsync(string endpoint, string? dataSource = null)
    {
        var body = XmlaSoapEnvelope("DBSCHEMA_CATALOGS");
        var xml = await PostXmlaAsync(endpoint, body); // uses the HttpClient helper shown earlier
        var rows = ParseRowset(xml);           // returns List<Dictionary<string,string>>
        var cats = rows
            .Select(r => r.TryGetValue("CATALOG_NAME", out var v) ? v : null)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct(StringComparer.Ordinal)
            .ToList();

        return cats;
    }

