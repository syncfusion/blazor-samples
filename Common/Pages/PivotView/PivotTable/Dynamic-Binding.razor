    private async void EnginePopulated(EnginePopulatedEventArgs args)
    {
        if (!IslooksLikeReport && shouldAutoConfigRef && (PivotCsvRef != null || PivotJsonRef != null || PivotOlapRef != null))
        {
            if (FileType == "JSON")
            {
                if (PivotJsonRef.DataSourceSettings.Values?.Count == 0)
                {
                    await Task.Delay(500);
                    await PivotJsonRef.ShowFieldListDialogAsync();
                }
            }
            else if (FileType == "CSV")
            {
                if (PivotCsvRef.DataSourceSettings.Values?.Count == 0)
                {
                    await Task.Delay(500);
                    await PivotCsvRef.ShowFieldListDialogAsync();
                }
            }
            else if (FileType == "OLAP")
            {
                if (PivotOlapRef.DataSourceSettings.Values?.Count == 0)
                {
                    await Task.Delay(500);
                    await PivotOlapRef.ShowFieldListDialogAsync();
                }
            }
            shouldAutoConfigRef = false;
        }
    }

