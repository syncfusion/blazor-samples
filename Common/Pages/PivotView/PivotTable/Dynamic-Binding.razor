    private async Task HandleOpenRemoteAsync()
    {
        if (string.IsNullOrWhiteSpace(RemoteUrl))
        {
            ErrorMessage = "Please enter a valid URL.";
            IsDialogOpen = false;
            IsErrorDialogOpen = true;
            return;
        }
        try
        {
            var type = string.Equals(DialogType, "CSV", StringComparison.OrdinalIgnoreCase) ? "CSV" : "JSON";
            IslooksLikeReport = false;
            await LoadRemoteAndBindAsync(type, RemoteUrl);
            IsDialogOpen = false;
        }
        catch (Exception ex)
        {
            ErrorMessage =
                $"Failed to load remote {DialogType}: {ex.Message}\n\n" +
                "Tip: Ensure the URL is accessible and allows CORS for your origin.";
            IsDialogOpen = false;
            IsErrorDialogOpen = true;
        }
    }

    private async Task LoadRemoteAndBindAsync(string kind, string url)
    {
        var cleanUrl = url.Trim();
        if (string.IsNullOrEmpty(cleanUrl))
            throw new Exception("Empty URL");

        if (kind.Equals("CSV", StringComparison.OrdinalIgnoreCase))
        {
            var response = await Http.GetAsync(cleanUrl);
            if (!response.IsSuccessStatusCode)
            {
                var errorText = await response.Content.ReadAsStringAsync();
                throw new Exception($"HTTP {response.StatusCode}: {response.ReasonPhrase}");
            }
            var csvString = await response.Content.ReadAsStringAsync();
            if (csvString.TrimStart().StartsWith("<!DOCTYPE html", StringComparison.OrdinalIgnoreCase) ||
                csvString.TrimStart().StartsWith("<html", StringComparison.OrdinalIgnoreCase))
            {
                throw new Exception("Invalid CSV: Received HTML error page instead of CSV.");
            }
            var arr = ParseCsvToList(csvString);
            if (arr.Count <= 1)
                throw new Exception("CSV appears empty or has only headers.");

            var headerLen = arr[0].Length;
            var inconsistent = arr.Skip(1).Any(r => r.Length != headerLen);
            if (inconsistent)
                throw new Exception("Malformed CSV: inconsistent number of columns.");

            lastRemoteRef = (cleanUrl, "CSV");
            ResetPivotSettings(PivotCsvRef, "CSV");
            FileType = "CSV";
            csvData = arr;
            shouldAutoConfigRef = true;
            StateHasChanged();
        }
        else // JSON
        {
            var response = await Http.GetAsync(cleanUrl);
            if (!response.IsSuccessStatusCode)
                throw new Exception($"HTTP {response.StatusCode}: {response.ReasonPhrase}");

            var jsonText = await response.Content.ReadAsStringAsync();
            var dataSource = new List<ExpandoObject>();
            dataSource = await ProcessJsonFile(jsonText);
            if (dataSource == null)
            {
                return;                
            }
            if (dataSource?.Count == 0)
            {
                await JS.InvokeVoidAsync("alert", "Invalid JSON at dataUrl: expected an array of objects(or under data)");
                return;
            }
            lastRemoteRef = (cleanUrl, "JSON");
            ResetPivotSettings(PivotJsonRef, "JSON");
            FileType = "JSON";
            jsonData = dataSource;
            shouldAutoConfigRef = true;
            StateHasChanged();
        }
    }

