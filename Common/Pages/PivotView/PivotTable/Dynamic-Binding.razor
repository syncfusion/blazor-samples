    // Universal handler for both CSV and JSON
    private async Task HandleConnectFileChange(InputFileChangeEventArgs e, string expectedType)
    {
        var file = e.File;
        if (file == null) return;
        string fileName = file.Name ?? string.Empty;
        // Enforce CSV-only when CSV mode is requested
        if (expectedType == "CSV" && !fileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            ErrorMessage = "Failed to load file as CSV. Please select a valid CSV file.";
            IsErrorDialogOpen = true;
            StateHasChanged();
            return;
        }
        bool isCsv = expectedType == "CSV" || fileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase);
        try
        {
            var stream = file.OpenReadStream(maxAllowedSize: 50_000_000); // 50MB
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            if (isCsv)
            {
                List<string[]> dataSource = ParseCsvToList(content);
                if (dataSource?.Count <= 1)
                {
                    ErrorMessage = "CSV appears empty or has only headers.";
                    IsErrorDialogOpen = true;
                    StateHasChanged();
                    return;
                }
                int headerLen = dataSource[0].Length;
                var inconsistent = dataSource.Skip(1).Any(r => r.Length != headerLen);
                if (inconsistent)
                {
                    ErrorMessage = "Malformed CSV: inconsistent number of columns.";
                    IsErrorDialogOpen = true;
                    StateHasChanged();
                    return;
                }
                IslooksLikeReport = false;
                lastRemoteRef = (string.Empty, "");
                ResetPivotSettings(PivotCsvRef, "CSV");
                FileType = "CSV";
                csvData = dataSource;
                shouldAutoConfigRef = true;
            }
            else
            {
                var dataSource = new List<ExpandoObject>();
                dataSource = await ProcessJsonFile(content);
                if (dataSource == null)
                    return;
                if (dataSource?.Count == 0)
                {
                    ErrorMessage = "No valid data rows found in JSON.";
                    IsErrorDialogOpen = true;
                    StateHasChanged();
                    return;
                }
                IslooksLikeReport = false;
                lastRemoteRef = (string.Empty, "");
                ResetPivotSettings(PivotJsonRef, "JSON");
                FileType = "JSON";
                jsonData = dataSource;
                shouldAutoConfigRef = true;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load file: {ex.Message}";
            IsErrorDialogOpen = true;
            StateHasChanged();
        }
        finally
        {
            PendingFileType = ""; // reset
        }
    }

    private static List<string[]> ParseCsvToList(string csv)
    {
        string[] headers = Array.Empty<string>();
        var result = new List<string[]>();
        if (string.IsNullOrWhiteSpace(csv)) return result;

        var lines = csv.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length <= 1) return result;

        headers = lines[0].Split(',').Select(h => h.Trim().Trim('"')).ToArray();

        for (int i = 0; i < lines.Length; i++)
        {
            var values = lines[i].Split(',');
            if (values.Length < headers.Length) continue; // skip incomplete rows
            result.Add(values);
        }

        return result;
    }

    private async Task<List<ExpandoObject>> ProcessJsonFile(string jsonText)
    {
        try
        {
            var jsonElement = JsonSerializer.Deserialize<JsonElement>(jsonText);
            JsonElement unwrappedData = jsonElement;
            // Unwrap if it has a "record" property
            if (unwrappedData.ValueKind == JsonValueKind.Object && unwrappedData.TryGetProperty("record", out var recordElem))
            {
                unwrappedData = recordElem;
            }
            // Check if it looks like a saved report (has typical report properties)
            bool looksLikeReport = unwrappedData.ValueKind == JsonValueKind.Object &&
                (unwrappedData.TryGetProperty("dataSourceSettings", out _) ||
                 unwrappedData.TryGetProperty("rows", out _) ||
                 unwrappedData.TryGetProperty("columns", out _) ||
                 unwrappedData.TryGetProperty("values", out _) ||
                 unwrappedData.TryGetProperty("record", out _));

            if (looksLikeReport)
            {
                IslooksLikeReport = true;
                var reportSettings = unwrappedData.TryGetProperty("dataSourceSettings", out var dssElem) ? dssElem : unwrappedData;
                if (reportSettings.ValueKind == JsonValueKind.String)
                {
                    var innerJson = reportSettings.GetString();
                    if (!string.IsNullOrWhiteSpace(innerJson))
                    {
                        using var innerDoc = JsonDocument.Parse(innerJson);
                        reportSettings = innerDoc.RootElement.Clone(); // Clone to keep it alive after dispose
                    }
                }

                var isOlapReport = reportSettings.TryGetProperty("providerType", out var providerProp)
                        && providerProp.ValueKind == JsonValueKind.String
                        && string.Equals(providerProp.GetString(), "SSAS", StringComparison.OrdinalIgnoreCase);
                await ApplyReportSettingsAsync(reportSettings, isOlapReport, unwrappedData, unwrappedData.TryGetProperty("dataSourceSettings", out _));
                return null;
            }
            // Case 2: Raw Data → Convert to List<ExpandoObject>
            JsonElement dataArray;
            if (unwrappedData.ValueKind == JsonValueKind.Object && unwrappedData.TryGetProperty("data", out var dataProp) && dataProp.ValueKind == JsonValueKind.Array)
                dataArray = dataProp;
            else if (unwrappedData.ValueKind == JsonValueKind.Array)
                dataArray = unwrappedData;
            else
            {
                ErrorMessage = "Invalid JSON: Provide a saved report or a non-empty array of objects (or under \"data\").";
                IsErrorDialogOpen = true;
                StateHasChanged();
                return null;
            }
            var expandoList = new List<ExpandoObject>();
            foreach (var item in dataArray.EnumerateArray())
            {
                if (item.ValueKind != JsonValueKind.Object)
                    continue; // Skip non-objects

                var expando = new ExpandoObject();
                var dictionary = (IDictionary<string, object>)expando;

                foreach (var prop in item.EnumerateObject())
                {
                    dictionary[prop.Name] = JsonElementToObject(prop.Value);
                }
                expandoList.Add(expando);
            }
            return expandoList;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to parse file as JSON: ${ex.Message}. Please select a valid JSON file.";
            IsErrorDialogOpen = true;
            StateHasChanged();
            return null;
        }
    }

    public async Task ApplyReportSettingsAsync(dynamic reportSettings, bool isOlapReport, JsonElement entireReportSettings, bool hasDataSourceSettings)
    {
        if (isOlapReport)
        {
            ResetPivotSettings(PivotOlapRef, "OLAP");
            FileType = "OLAP";
            shouldAutoConfigRef = true;
            StateHasChanged();
            await Task.Delay(100);

            IDictionary<string, object> report = new Dictionary<string, object>()
                {
                    { "dataSourceSettings", entireReportSettings.TryGetProperty("dataSourceSettings", out var dssElem) ? JsonSerializer.Serialize(dssElem) : null },
                    { "gridSettings", entireReportSettings.TryGetProperty("gridSettings", out var gs) ? JsonSerializer.Serialize(gs) : null },
                    { "chartSettings", entireReportSettings.TryGetProperty("chartSettings", out var cs) ? JsonSerializer.Serialize(cs) : null },
                    { "displayOption", entireReportSettings.TryGetProperty("displayOption", out var dop) ? JsonSerializer.Serialize(dop) : null }
                };
            PivotOlapRef.LoadPersistDataAsync(JsonSerializer.Serialize(report));
        }
        else
        {
            /* CleanOlapForRelational(); */
            string maybeDataUrl = reportSettings.TryGetProperty("url", out JsonElement validUrl) ? validUrl.GetString() : string.Empty;
            bool dataSourceIsMissingOrEmpty = !reportSettings.TryGetProperty("dataSource", out JsonElement dsElem) ||
                                    dsElem.ValueKind != JsonValueKind.Array ||
                                    dsElem.GetArrayLength() == 0;
            string dataType = reportSettings.TryGetProperty("type", out JsonElement type) ? type.GetString() : "JSON";

            if (dataSourceIsMissingOrEmpty)
            {
                try
                {
                    if (!string.IsNullOrEmpty(maybeDataUrl) && maybeDataUrl.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
                    {
                        await LoadRemoteAndBindAsync("JSON", maybeDataUrl);
                        await Task.Delay(50);
                    }
                    else if (!string.IsNullOrEmpty(maybeDataUrl) && maybeDataUrl.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
                    {
                        await LoadRemoteAndBindAsync("CSV", maybeDataUrl);
                        await Task.Delay(50);
                    }
                }
                catch (Exception)
                {
                    if (dataType.Equals("csv", StringComparison.OrdinalIgnoreCase))
                    {
                        ResetPivotSettings(PivotCsvRef, "JSON");
                    }
                    else if (dataType.Equals("json", StringComparison.OrdinalIgnoreCase))
                    {
                        ResetPivotSettings(PivotJsonRef, "JSON");
                    }
                }
            }
            else
            {
                if (string.Equals(dataType, "CSV", StringComparison.OrdinalIgnoreCase))
                {
                    // CSV case: expect array of arrays (string[][] in JSON)
                    var dataSource = new List<string[]>();
                    foreach (var rowElement in dsElem.EnumerateArray())
                    {
                        if (rowElement.ValueKind != JsonValueKind.Array)
                            throw new InvalidOperationException("CSV dataSource expects array of arrays.");

                        var row = rowElement.EnumerateArray()
                                            .Select(item => item.GetString() ?? string.Empty)
                                            .ToArray();
                        dataSource.Add(row);
                    }

                    if (dataSource.Count <= 1)
                        throw new Exception("CSV appears empty or has only headers.");

                    var headerLen = dataSource[0].Length;
                    var inconsistent = dataSource.Skip(1).Any(r => r.Length != headerLen);
                    if (inconsistent)
                        throw new Exception("Malformed CSV: inconsistent number of columns.");

                    ResetPivotSettings(PivotCsvRef, "CSV");
                    FileType = "CSV";
                    csvData = dataSource;
                    shouldAutoConfigRef = true;
                    StateHasChanged();
                    await Task.Delay(100);
                }
                else
                {
                    // Default/JSON case: array of objects → convert to List<ExpandoObject>
                    var dataSource = new List<ExpandoObject>();
                    foreach (var item in dsElem.EnumerateArray())
                    {
                        if (item.ValueKind != JsonValueKind.Object)
                            continue; // Skip non-objects

                        var expando = new ExpandoObject();
                        var dictionary = (IDictionary<string, object>)expando;

                        foreach (var prop in item.EnumerateObject())
                        {
                            dictionary[prop.Name] = JsonElementToObject(prop.Value);
                        }

                        dataSource.Add(expando);
                    }
                    if (dataSource?.Count == 0)
                    {
                        await JS.InvokeVoidAsync("alert", "Invalid JSON at dataUrl: expected an array of objects(or under data)");
                        return;
                    }
                    ResetPivotSettings(PivotJsonRef, "JSON");
                    FileType = "JSON";
                    jsonData = dataSource;
                    shouldAutoConfigRef = true;
                    StateHasChanged();
                    await Task.Delay(100);
                }
            }

            var jsonElement = entireReportSettings;
            JsonObject root = JsonNode.Parse(entireReportSettings.GetRawText())!.AsObject();
            if (root.TryGetPropertyValue("dataSourceSettings", out var dss) && dss is JsonObject dssObj && !IsUrlNullOrEmpty(dssObj))
            {
                // set url to empty (create it if missing)
                dssObj["url"] = "";
                var updatedJson = root.ToJsonString(new JsonSerializerOptions { WriteIndented = false });
                jsonElement = JsonSerializer.Deserialize<JsonElement>(updatedJson);
            }
            if (dataType == "CSV")
            {
                IDictionary<string, object> report = new Dictionary<string, object>()
                {
                    { "dataSourceSettings", jsonElement.TryGetProperty("dataSourceSettings", out var dssElem) ? JsonSerializer.Serialize(dssElem) : null },
                    { "gridSettings", jsonElement.TryGetProperty("gridSettings", out var gs) ? JsonSerializer.Serialize(gs) : null },
                    { "chartSettings", jsonElement.TryGetProperty("chartSettings", out var cs) ? JsonSerializer.Serialize(cs) : null },
                    { "displayOption", jsonElement.TryGetProperty("displayOption", out var dop) ? JsonSerializer.Serialize(dop) : null }
                };

                PivotCsvRef.LoadPersistDataAsync(JsonSerializer.Serialize(report));
            }
            else if (dataType == "JSON")
            {
                IDictionary<string, object> report = new Dictionary<string, object>()
                {
                    { "dataSourceSettings", jsonElement.TryGetProperty("dataSourceSettings", out var dssElem) ? JsonSerializer.Serialize(dssElem) : null },
                    { "gridSettings", jsonElement.TryGetProperty("gridSettings", out var gs) ? JsonSerializer.Serialize(gs) : null },
                    { "chartSettings", jsonElement.TryGetProperty("chartSettings", out var cs) ? JsonSerializer.Serialize(cs) : null },
                    { "displayOption", jsonElement.TryGetProperty("displayOption", out var dop) ? JsonSerializer.Serialize(dop) : null }
                };
                PivotJsonRef.LoadPersistDataAsync(JsonSerializer.Serialize(report));
            }
        }
    }

    private bool IsUrlNullOrEmpty(JsonObject dssObj)
    {
        if (!dssObj.TryGetPropertyValue("url", out JsonNode? urlNode) || urlNode is null)
            return true;

        string? url = urlNode.GetValue<string?>();
        return string.IsNullOrWhiteSpace(url);
    }

    // Helper: Converts JsonElement → proper .NET object (string, int, double, bool, List, Expando, null)
    public static object? JsonElementToObject(JsonElement element)
    {
        switch (element.ValueKind)
        {
            case JsonValueKind.String:
                return element.GetString();
            case JsonValueKind.Number:
                return element.TryGetInt64(out long l) ? l : element.GetDouble();
            case JsonValueKind.True:
                return true;
            case JsonValueKind.False:
                return false;
            case JsonValueKind.Null:
                return null;
            case JsonValueKind.Array:
                return element.EnumerateArray().Select(JsonElementToObject).ToList();
            case JsonValueKind.Object:
                {
                    var obj = new ExpandoObject();
                    var dict = (IDictionary<string, object?>)obj;
                    foreach (var prop in element.EnumerateObject())
                    {
                        dict[prop.Name] = JsonElementToObject(prop.Value);
                    }
                    return obj;
                }
            default:
                return null;
        }
    }

