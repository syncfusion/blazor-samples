@code {
    // URL and UI state
    public string olapProxyUrl { get; set; } = "https://bi.syncfusion.com/olap/msmdpump.dll";
    private string OlapUiMessage { get; set; } = string.Empty;
    private bool OlapConnected { get; set; }

    // Loading flags
    private bool LoadingSources { get; set; }
    private bool LoadingCatalogs { get; set; }
    private bool LoadingCubes { get; set; }

    // Data
    private List<string> OlapDataSources { get; set; } = new();
    private List<string> OlapCatalogs { get; set; } = new();
    private List<string> OlapCubes { get; set; } = new();

    // Selections
    private string SelectedDataSource { get; set; } = string.Empty;
    private string SelectedCatalog { get; set; } = string.Empty;
    private string SelectedCube { get; set; } = string.Empty;

    private string OlapUrl = "https://bi.syncfusion.com/olap/msmdpump.dll";
    private string OlapCatalog = "Adventure Works DW 2008 SE";
    private string OlapCube = "Adventure Works";

    // Variables corresponding to the JS refs (you need to maintain these in your component)
    private object dataSource; // The inline data if present
    private (string url, string kind) lastRemoteRef; // e.g., a record or class holding the last remote URL and kind ('JSON' or 'CSV')

    [Inject]
    private HttpClient Http { get; set; } = default!;
    private Theme Theme { get; set; }
    public bool IsDialogOpen { get; set; }
    public string DialogType { get; set; }
    public string RemoteUrl { get; set; } = string.Empty;
    public string ErrorMessage { get; set; } = string.Empty;
    private bool IsErrorDialogOpen { get; set; }
    public static readonly Dictionary<string, string> defaultUrls = new Dictionary<string, string>
    {
        ["CSV"] = "https://cdn.syncfusion.com/data/sales-analysis.csv",
        ["JSON"] = "https://cdn.syncfusion.com/data/sales-analysis.json"
    };
    public List<ExpandoObject> jsonData { get; set; } = new List<ExpandoObject>();
    public List<string[]> csvData { get; set; }
    public SfPivotView<ExpandoObject>? PivotJsonRef;
