    private async Task SaveReportAsync()
    {
        if (PivotJsonRef == null && PivotCsvRef == null && PivotOlapRef == null)
            return;

        void Download(string content, string mime, string filename)
        {
            var bytes = Encoding.UTF8.GetBytes(content);
            var base64 = Convert.ToBase64String(bytes);

            // Use JS interop to trigger download
            JS.InvokeVoidAsync("eval", $@"
            const data = Uint8Array.from(atob('{base64}'), c => c.charCodeAt(0));
            const blob = new Blob([data], {{ type: '{mime}' }});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = '{filename}';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        ");
        }

        try
        {
            string persisted = string.Empty;

            // Get persisted data from the correct pivot based on FileType
            persisted = FileType switch
            {
                "JSON" => await PivotJsonRef.GetPersistDataAsync(),
                "CSV" => await PivotCsvRef.GetPersistDataAsync(),
                "OLAP" => await PivotOlapRef.GetPersistDataAsync(),
                _ => throw new InvalidOperationException("Unknown FileType")
            };

            // Parse into mutable JsonNode (best practice in .NET 6+)
            JsonNode? reportNode = JsonNode.Parse(persisted);
            if (reportNode is not JsonObject rootObj)
                throw new Exception("Invalid pivot persist data format.");
            JsonObject? dssObj = null;
            bool isOlapReport = false;
            object[]? preservedInlineData = null;

            if (rootObj.TryGetPropertyValue("dataSourceSettings", out JsonNode? dssNode))
            {
                if (dssNode is JsonValue jv6 && jv6.TryGetValue<string>(out var olapJson) && !string.IsNullOrWhiteSpace(olapJson))
                {
                    var parsed = JsonNode.Parse(olapJson) as JsonObject ?? new JsonObject();
                    if (parsed is JsonObject dssObjLocal)
                    {
                        dssObj = dssObjLocal;
                        // Check providerType
                        if (dssObj.TryGetPropertyValue("providerType", out JsonNode? providerNode) &&
                            providerNode is JsonValue pv &&
                            pv.TryGetValue<string>(out var provider))
                        {
                            isOlapReport = string.Equals(provider, "SSAS", StringComparison.OrdinalIgnoreCase);
                        }
                        rootObj["dataSourceSettings"] = parsed;
                    }
                }
            }
            // Remove inline dataSource if present and not OLAP
            if (!isOlapReport && dssObj is not null)
            {
                if (
                    dssObj.TryGetPropertyValue("dataSource", out JsonNode? dataSourceNode) &&
                    dataSourceNode is JsonArray dataArray &&
                    dataArray.Count > 0)
                {
                    // Preserve the inline data for potential later use
                    // Option 1: Deserialize directly from JsonNode
                    preservedInlineData = dataSourceNode.Deserialize<object[]?>();

                    // Replace with empty array
                    dssObj["dataSource"] = new JsonArray();
                }
            }

            // Always remove pivotValues (it's large and not needed in saved report)
            rootObj.Remove("pivotValues");

            // Fallback: if no inline data, add remote URL reference
            bool hasInline = dataSource != null;
            // If dataSourceSettings is a stringified JSON, parse it first
            if (!hasInline && !string.IsNullOrEmpty(lastRemoteRef.url) && dssNode is JsonValue jv && jv.TryGetValue<string>(out var innerJson) && !string.IsNullOrWhiteSpace(innerJson))
            {
                var parsed = JsonNode.Parse(innerJson) as JsonObject ?? new JsonObject();
                if (lastRemoteRef.kind == "JSON")
                {
                    parsed["url"] = lastRemoteRef.url;
                    parsed["type"] = "JSON";
                }
                else if (lastRemoteRef.kind == "CSV")
                {
                    parsed["url"] = lastRemoteRef.url;
                    parsed["type"] = "CSV";
                }
                // Option A: keep it as an object going forward
                rootObj["dataSourceSettings"] = parsed;
            }
            else
            {
                if (FileType == "CSV")
                {
                    var parsed = dssNode;
                    if (dssNode is JsonValue jv5 && jv5.TryGetValue<string>(out var innerJson1) && !string.IsNullOrWhiteSpace(innerJson1))
                    {
                        parsed = JsonNode.Parse(innerJson1) as JsonObject ?? new JsonObject();
                    }
                    // parsed is your JsonObject for dataSourceSettings
                    if (csvData is not null)
                    {
                        JsonNode dataNode = JsonSerializer.SerializeToNode(csvData)!; // List<string[]> -> JsonArray
                        parsed["dataSource"] = dataNode;
                        // keep the rest of your code
                        rootObj["dataSourceSettings"] = parsed;
                    }
                }
                if (FileType == "JSON")
                {
                    var parsed = dssNode;
                    if (dssNode is JsonValue jv5 && jv5.TryGetValue<string>(out var innerJson1) && !string.IsNullOrWhiteSpace(innerJson1))
                    {
                        parsed = JsonNode.Parse(innerJson1) as JsonObject ?? new JsonObject();
                    }
                    // parsed is your JsonObject for dataSourceSettings
                    if (jsonData is not null)
                    {
                        JsonNode dataNode = JsonSerializer.SerializeToNode(jsonData)!;
                        parsed["dataSource"] = dataNode;
                        // keep the rest of your code
                        rootObj["dataSourceSettings"] = parsed;
                    }
                }
            }

            if (rootObj.TryGetPropertyValue("gridSettings", out JsonNode? gs) && gs is JsonValue jv1 && jv1.TryGetValue<string>(out var gsJson) && !string.IsNullOrWhiteSpace(gsJson))
            {
                var parsed = JsonNode.Parse(gsJson) as JsonObject ?? new JsonObject();
                rootObj["gridSettings"] = parsed;
            }
            if (rootObj.TryGetPropertyValue("chartSettings", out JsonNode? cs) && cs is JsonValue jv2 && jv2.TryGetValue<string>(out var csJson) && !string.IsNullOrWhiteSpace(csJson))
            {
                var parsed = JsonNode.Parse(csJson) as JsonObject ?? new JsonObject();
                rootObj["chartSettings"] = parsed;
            }
            if (rootObj.TryGetPropertyValue("displayOption", out JsonNode? dOpt) && dOpt is JsonValue jv3 && jv3.TryGetValue<string>(out var dOptJson) && !string.IsNullOrWhiteSpace(dOptJson))
            {
                var parsed = JsonNode.Parse(dOptJson) as JsonObject ?? new JsonObject();
                rootObj["displayOption"] = parsed;
            }

            // Serialize with pretty printing
            string json = reportNode.ToJsonString(new JsonSerializerOptions { WriteIndented = true });

            Download(json, "application/json", "pivot.json");
        }
        catch (Exception err)
        {
            await JS.InvokeVoidAsync("alert", $"Failed to save: {err.Message}");
        }
    }

