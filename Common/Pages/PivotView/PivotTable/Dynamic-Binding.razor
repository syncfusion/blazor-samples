            IsDialogOpen = true;
            StateHasChanged();
            return;
        }
    }

    public static void ResetPivotSettings(dynamic pivotRef, string type)
    {
        if (pivotRef is null || pivotRef.DataSourceSettings is null) return;

        if (type == "JSON" || type == "CSV")
        {
            pivotRef.DataSourceSettings.Url = string.Empty;
        }
        pivotRef.DataSourceSettings.Rows = new List<PivotViewRow>();
        pivotRef.DataSourceSettings.Columns = new List<PivotViewColumn>();
        pivotRef.DataSourceSettings.Values = new List<PivotViewValue>();
        pivotRef.DataSourceSettings.Filters = new List<PivotViewFilter>();

        pivotRef.DataSourceSettings.ConditionalFormatSettings = new List<PivotViewConditionalFormatSetting>();
        pivotRef.DataSourceSettings.FormatSettings = new List<PivotViewFormatSetting>();
        pivotRef.DataSourceSettings.DrilledMembers = new List<PivotViewDrilledMember>();
        pivotRef.DataSourceSettings.FieldMapping = new List<PivotViewField>();
        pivotRef.DataSourceSettings.ExcludeFields = Array.Empty<string>();
        pivotRef.DataSourceSettings.FilterSettings = new List<PivotViewFilterSetting>();
        pivotRef.DataSourceSettings.SortSettings = new List<PivotViewSortSetting>();
        pivotRef.DataSourceSettings.ValueSortSettings = new PivotViewValueSortSettings();
        pivotRef.DataSourceSettings.CalculatedFieldSettings = new List<PivotViewCalculatedFieldSetting>();
        pivotRef.DataSourceSettings.GroupSettings = new List<PivotViewGroupSetting>();

        pivotRef.DataSourceSettings.ExpandAll = false;
        pivotRef.DataSourceSettings.ShowGrandTotals = true;
        pivotRef.DataSourceSettings.ShowRowGrandTotals = true;
        pivotRef.DataSourceSettings.ShowColumnGrandTotals = true;
        pivotRef.DataSourceSettings.ShowSubTotals = true;
        pivotRef.DataSourceSettings.ShowRowSubTotals = true;
        pivotRef.DataSourceSettings.ShowColumnSubTotals = true;
    }

