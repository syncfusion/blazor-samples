    // Equivalent to:
    // const discoverCubes = async (endpoint, catalog) => { ... }
    public async Task<List<string>> DiscoverCubesAsync(string endpoint, string catalog)
    {
        if (string.IsNullOrWhiteSpace(catalog))
            throw new ArgumentException("Catalog is required.", nameof(catalog));

        var body = XmlaSoapEnvelope(
            requestType: "MDSCHEMA_CUBES",
            restrictions: new Dictionary<string, object>
            {
                { "CATALOG_NAME", catalog }
            }
        );

        var xml = await PostXmlaAsync(endpoint, body);   // See earlier HttpClient helper
        var rows = ParseRowset(xml);              // Returns List<Dictionary<string,string>>

        var cubes = rows
            .Where(r => r.TryGetValue("CUBE_SOURCE", out var src) && src == "1")
            .Select(r => r.TryGetValue("CUBE_NAME", out var name) ? name : null)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.Ordinal)
            .ToList();

        return cubes;
    }

