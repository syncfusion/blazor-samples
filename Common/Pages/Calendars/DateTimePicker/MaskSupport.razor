@page "/DateTime-Picker/MaskSupport"

@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.DropDowns

@*Hidden:Lines*@
@inherits SampleBaseComponent;
@*End:Hidden*@
<ActionDescription>
<p>
    This sample demonstrates the datetime masking functionality in the DateTimePicker component. It allows users to enter valid values for each mask pattern of the datetime masking.
  </p>
  <p>
        The DateTimePicker has an <a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Calendars.SfDatePicker-1.html#Syncfusion_Blazor_Calendars_SfDatePicker_1_EnableMask" target="_blank" aria-label="Enable Mask">EnableMask</a> property that enables datetime masking support. The mask pattern is defined based on the provided date and time format to the component. If the <a href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Calendars.DatePickerModel.html#Syncfusion_Blazor_Calendars_DatePickerModel_Format" target="_blank" rel="noopener" aria-label="Class reference of Format property in DateTimePicker">Format</a> is not specified, the mask pattern is formed based on the default format of the current culture.
  </p>
</ActionDescription>


<div class="col-lg-12">
    <div class="col-lg-8 control-section">
        <div class="control-wrapper">
            <label class="example-label">Select Date and Time</label>
            <SfDateTimePicker TValue="DateTime?" @bind-Value="@DateValue" EnableMask=true Format="@FormatString" StrictMode=true ShowClearButton="true" FullScreen="true" aria-label="Date and time picker with mask support">
                <DateTimePickerMaskPlaceholder Day="day" Month="month" Year="year" Hour="hour" Minute="minute" Second="second" DayOfWeek="weekday"></DateTimePickerMaskPlaceholder>
            </SfDateTimePicker>
        </div>
    </div>
    <PropertyPanel ControlSecClass="col-lg-8">
        <label class="example-label">Choose a format</label>
        <SfDropDownList TItem="DateFormat" TValue="string" PopupHeight="230px" @bind-Index="@Index" DataSource="@Formats">
            <DropDownListEvents TItem="DateFormat" TValue="string" ValueChange="OnChange"></DropDownListEvents>
            <DropDownListFieldSettings Text="Text" Value="Id"></DropDownListFieldSettings>
        </SfDropDownList>
     </PropertyPanel>
</div>

<style>
    .control-wrapper {
        max-width: 350px;
        margin: 0 auto;
        padding: 50px 0px 0px;
    }
    
    .example-label {
        font-size: 14px;
        margin-bottom: 6px;
    }

</style>

@code {
    private int? Index { get; set; } = 0;
    public DateTime? DateValue { get; set; } = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 10);
    
    public class DateFormat
    {
        public string? Id { get; set; }
        public string? Text { get; set; }
    }
    public string? FormatString { get; set; } = "F";

    private List<DateFormat> Formats = new List<DateFormat>()
    {
        new DateFormat() { Id = "F", Text = "Full Datetime(long time)" },
        new DateFormat() { Id = "f", Text = "Full Datetime(short time)" },
        new DateFormat() { Id = "R", Text = "RFC1123" },
        new DateFormat() { Id = "G", Text = "General Datetime(long time)" },
        new DateFormat() { Id = "g", Text = "General Datetime(short time)" },
        new DateFormat() { Id = "s", Text = "Sortable Datetime" },
        new DateFormat() { Id = "U", Text = "Universal Full Datetime" },
        new DateFormat() { Id = "u", Text = "Universal Sortable Datetime" },
    };
    public void OnChange(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, DateFormat> args)
    {
        this.FormatString = args.ItemData?.Id;
    }
}
