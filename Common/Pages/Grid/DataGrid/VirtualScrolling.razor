@page "/datagrid/virtual-scrolling"

@using Syncfusion.Blazor.Grids
@inject Microsoft.AspNetCore.Components.NavigationManager UriHelper
@*Hidden:Lines*@
@using BlazorDemos
@using blazor_flightbooking
@inherits SampleBaseComponent;
@inject NavigationManager NavigationManager


@*End:Hidden*@

<ActionDescription>
    <p>This sample demonstrates the DataGrid row and column virtualization feature for efficiently rendering large flight booking datasets.</p>

    <p>The Blazor DataGrid UI virtualization enables rendering only visible rows and columns in the viewport without buffering the entire datasource. This significantly improves performance when working with large datasets by reducing DOM elements and memory usage.</p>

    <p><strong>Row Virtualization:</strong></p>
    <p>Enable row virtualization by setting the <a target='_blank' href='https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Grids.SfGrid-1.html#Syncfusion_Blazor_Grids_SfGrid_1_EnableVirtualization' aria-label="Navigate to the EnableVirtualization property reference for DataGrid component" rel="noopener">EnableVirtualization</a> property to <strong>true</strong>. When enabled, the <a target='_blank' href='https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Grids.SfGrid-1.html#Syncfusion_Blazor_Grids_SfGrid_1_Height' aria-label="Navigate to the Height property reference for DataGrid component" rel="noopener">Height</a> property must be defined for proper virtual scrolling calculations.</p>

    <p><strong>Column Virtualization:</strong></p>
    <p>Enable column virtualization by setting the <a target='_blank' href='https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Grids.SfGrid-1.html#Syncfusion_Blazor_Grids_SfGrid_1_EnableColumnVirtualization' aria-label="Navigate to the EnableColumnVirtualization property reference for DataGrid component" rel="noopener">EnableColumnVirtualization</a> property to <strong>true</strong>. When enabled, the <a target='_blank' href='https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Grids.SfGrid-1.html#Syncfusion_Blazor_Grids_SfGrid_1_Width' aria-label="Navigate to the Width property reference for DataGrid component" rel="noopener">Width</a> property must be defined for accurate column virtualization.</p>

    <p>In this demo:</p>
    <ul>
        <li>The DataGrid renders 10,000 flight booking records with 20 columns</li>
        <li>Both row and column virtualization are enabled for optimal performance</li>
        <li>Realistic flight booking data with meaningful business attributes</li>
        <li>Custom templates for passenger names (avatar badges) and booking status</li>
        <li>Currency formatting for fare amounts and date formatting for flight schedules</li>
        <li>Rows load on-demand as you scroll vertically</li>
        <li>Columns load on-demand as you scroll horizontally</li>
        <li>Data editing is fully supported with virtualization enabled</li>
        <li>Column chooser allows showing or hiding columns dynamically</li>
    </ul>

    <p>Virtualization dramatically improves performance with large datasets by maintaining a fixed number of DOM elements regardless of the data size.</p>

    <p>For more detailed information about virtual scrolling, refer to the <a target='_blank' href='https://blazor.syncfusion.com/documentation/datagrid/virtual' aria-label="Navigate to the documentation for virtualization in DataGrid component" rel="noopener">virtualization documentation</a>.</p>
</ActionDescription>


<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            @{
                if (Data)
                {
                    <div class="apply-padding"><span id="initialload" class="topload">Loading 10,000 Flight Booking Records and 20 Columns</span></div>
                    <div class="loading">
                        <span id="spancontrol" class="visible">Generating Data </span>
                        <img src="@UriHelper.ToAbsoluteUri($"{SampleService?.WebAssetsPath}images/data-grid/spinner.gif")" />
                    </div>
                }
                else
                {
                    <div class="apply-padding"><span id="afterload" class="topload">Loaded 10,000 Flight Booking Records and 20 Columns</span> </div>
                }
            }
            <SfGrid DataSource="@GridData" Height="410" Width="auto" EnableHover="false" ShowColumnChooser="true" EnableVirtualization="true" EnableColumnVirtualization="true"
                    Toolbar="@(new List<string>() { "Edit", "Delete", "Update", "Cancel", "ColumnChooser" })">
                <GridEditSettings AllowAdding="true" AllowDeleting="true" AllowEditing="true"></GridEditSettings>
                <GridPageSettings PageSize="80"></GridPageSettings>
                <GridColumns>
                    <GridColumn Field=@nameof(FlightBookingRecord.BookingId) HeaderText="Booking ID" IsPrimaryKey=true IsIdentity="true" ValidationRules="@(new ValidationRules { Required = true })" Width="140"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.PassengerName) HeaderText="Passenger Name" Type="ColumnType.String" Width="180" ShowInColumnChooser="false" ValidationRules="@(new ValidationRules { Required = true })"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.Email) HeaderText="Email" Type="ColumnType.String" Width="220"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.FlightNumber) HeaderText="Flight Number" Type="ColumnType.String" Width="150"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.AirlineCode) HeaderText="Airline" Type="ColumnType.String" Width="150"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.DepartureAirport) HeaderText="From" Type="ColumnType.String" Width="190"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.ArrivalAirport) HeaderText="To" Type="ColumnType.String" Width="190"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.DepartureDate) HeaderText="Departure" Format="MM/dd/yyyy HH:mm" Type="ColumnType.DateTime" TextAlign="TextAlign.Right" Width="160" EditType="EditType.DateTimePickerEdit"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.ArrivalDate) HeaderText="Arrival" Format="MM/dd/yyyy HH:mm" Type="ColumnType.DateTime" TextAlign="TextAlign.Right" Width="160" EditType="EditType.DateTimePickerEdit"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.SeatNumber) HeaderText="Seat" Type="ColumnType.String" Width="80"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.ClassOfTravel) HeaderText="Class" Type="ColumnType.String" Width="150">
                        <Template>
                            @{
                                // Extract flight booking record from grid context
                                var record = context as FlightBookingRecord;
                                // Select CSS class based on class of travel
                                var classStyle = record?.ClassOfTravel switch
                                {
                                    ClassOfTravel.Economy => "class-economy",
                                    ClassOfTravel.PremiumEconomy => "class-premium-economy",
                                    ClassOfTravel.Business => "class-business",
                                    ClassOfTravel.FirstClass => "class-first",
                                    _ => "class-default"
                                };
                            }
                            <!-- Display class of travel as styled badge -->
                            <span class="class-badge @classStyle">@record?.ClassOfTravel</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.BookingDate) HeaderText="Booked On" Format="MM/dd/yyyy" Type="ColumnType.DateTime" TextAlign="TextAlign.Right" Width="120"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.BookingAmount) HeaderText="Ticket Price" Format="C2" TextAlign="TextAlign.Right" Type="ColumnType.Decimal" Width="120"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.TaxAmount) HeaderText="Tax" Format="C2" TextAlign="TextAlign.Right" Type="ColumnType.Decimal" Width="150"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.TotalFare) HeaderText="Total Fare" Format="C2" TextAlign="TextAlign.Right" Type="ColumnType.Decimal" Width="150"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.Status) HeaderText="Status" Type="ColumnType.String" Width="160">
                        <Template>
                            @{
                                // Extract flight booking record from grid context
                                var record = context as FlightBookingRecord;
                                // Select CSS class based on booking status value
                                var statusClass = record?.Status switch
                                {
                                    BookingStatus.Confirmed => "status-confirmed",
                                    BookingStatus.CheckedIn => "status-checked-in",
                                    BookingStatus.Completed => "status-completed",
                                    BookingStatus.Pending => "status-pending",
                                    BookingStatus.Cancelled => "status-cancelled",
                                    BookingStatus.NoShow => "status-noshow",
                                    _ => "status-default"
                                };
                            }
                            <!-- Display status as styled badge -->
                            <span class="status-badge @statusClass">@record?.Status</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.PaymentMethod) HeaderText="Payment" Type="ColumnType.String" Width="130"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.MealPreference) HeaderText="Meal" Type="ColumnType.String" Width="120"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.BaggageAllowance) HeaderText="Baggage (bags)" TextAlign="TextAlign.Right" Type="ColumnType.Integer" Width="150"></GridColumn>
                    <GridColumn Field=@nameof(FlightBookingRecord.CheckedIn) HeaderText="Checked In" Type="ColumnType.Boolean" Width="120">
                        <Template>
                            @{
                                // Extract flight booking record from grid context
                                var record = context as FlightBookingRecord;
                                // Select CSS class based on checked-in status
                                var checkinClass = record?.CheckedIn == true ? "checkin-yes" : "checkin-no";
                                var checkinText = record?.CheckedIn == true ? "Yes" : "No";
                            }
                            <!-- Display checked-in status as badge -->
                            <span class="checkin-badge @checkinClass">@checkinText</span>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        </div>
    </div>
</div>

@*Hidden:Lines*@
<style>
    .visible {
        display: inline-block;
        font-size: 18px;
        color: rgba(0,0,0,1);
    }

    .loading {
        position: absolute;
        height: 92%;
        width: 100%;
        background-color: rgba(1,1,1,0.2);
        z-index: 10000;
        display: flex;
        align-items: center;
        padding-left: 44%;
    }

    .topload {
        font-size: 15px;
    }

    .apply-padding {
        padding-bottom: 10px;
    }

    /* Status Badge Styles */
    .status-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-confirmed {
        background-color: #28a745;
        color: #ffffff;
        border: 1px solid #1e7e34;
    }

    .status-checked-in {
        background-color: #007bff;
        color: #ffffff;
        border: 1px solid #0056b3;
    }

    .status-completed {
        background-color: #20c997;
        color: #ffffff;
        border: 1px solid #117a65;
    }

    .status-pending {
        background-color: #ffc107;
        color: #000000;
        border: 1px solid #e0a800;
    }

    .status-cancelled {
        background-color: #dc3545;
        color: #ffffff;
        border: 1px solid #c82333;
    }

    .status-noshow {
        background-color: #6c757d;
        color: #ffffff;
        border: 1px solid #545b62;
    }

    .status-default {
        background-color: #e9ecef;
        color: #495057;
        border: 1px solid #dee2e6;
    }

    /* Class of Travel Badge Styles */
    .class-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .class-economy {
        background-color: #e3f2fd;
        color: #1565c0;
        border: 1px solid #90caf9;
    }

    .class-premium-economy {
        background-color: #fff3e0;
        color: #e65100;
        border: 1px solid #ffe0b2;
    }

    .class-business {
        background-color: #f3e5f5;
        color: #6a1b9a;
        border: 1px solid #ce93d8;
    }

    .class-first {
        background-color: #fff8e1;
        color: #f57f17;
        border: 1px solid #fff59d;
    }

    .class-default {
        background-color: #f5f5f5;
        color: #424242;
        border: 1px solid #e0e0e0;
    }

    /* Check-in Badge Styles */
    .checkin-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .checkin-yes {
        background-color: #4caf50;
        color: #ffffff;
        border: 1px solid #388e3c;
    }

    .checkin-no {
        background-color: #f44336;
        color: #ffffff;
        border: 1px solid #d32f2f;
    }
</style>
@*End:Hidden*@

@code {
    /// <summary>Collection of flight booking records bound to the grid.</summary>
    public List<FlightBookingRecord>? GridData { get; set; }

    /// <summary>Flag to manage loading state during data generation.</summary>
    public bool Data = true;

    /// <summary>Initialize grid with flight booking records when component loads.</summary>
    protected override async Task OnInitializedAsync()
    {
        GridData = await GetAllRecordsAsync();
        Data = false;
    }

    /// <summary>Asynchronously retrieve all flight booking records for display.</summary>
    /// <returns>Collection of 10,000 flight booking records.</returns>
    public async Task<List<FlightBookingRecord>> GetAllRecordsAsync()
    {
        return FlightBookingData.GetAllRecords();
    }
}
