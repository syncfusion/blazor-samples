@page "/datagrid/column-template"

@using Syncfusion.Blazor.Grids
@inject Microsoft.AspNetCore.Components.NavigationManager UriHelper
@*Hidden:Lines*@
@using BlazorDemos
@using blazor_employeedatasource

@inherits SampleBaseComponent;
@inject NavigationManager NavigationManager


@*End:Hidden*@

<ActionDescription>
    <p>This sample demonstrates the Syncfusion<sup style="font-size:70%">&reg;</sup> Blazor DataGrid column template feature for creating custom column content.</p>
    <p>The <a target='_blank' href='https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Grids.GridColumn.html#Syncfusion_Blazor_Grids_GridColumn_Template' aria-label="Navigate to the Template property reference for Grid column">Template</a> property of the <a target='_blank' href='https://help.syncfusion.com/cr/aspnetcore-blazor/Syncfusion.Blazor.Grids.GridColumn.html' aria-label="Navigate to the class reference for GridColumn">GridColumn</a> component enables the creation of custom layouts and the display of custom element values for each cell. The implicit <strong>Context</strong> parameter provides access to the row data within the template.</p>
    <p>This sample demonstrates several column template use cases: an <strong>Employee Image</strong> column with employee photographs, an <strong>Employee ID</strong> column with clickable hyperlinks to employee profile pages, and an <strong>Employee Name</strong> column combining name and email in a custom layout. Additionally, <strong>Team</strong> and <strong>Shift</strong> columns display color-coded badges representing different team assignments (Frontend, Backend, DevOps, QA, Analytics, Design, Product) and shift types (Regular Shift, Night Shift, Rotational Shift).</p>
    <p>For more detailed information about column templates, refer to the <a target='_blank' href='https://blazor.syncfusion.com/documentation/datagrid/column-template' aria-label="Navigate to the documentation for column template in DataGrid component">column template documentation</a>.</p>
</ActionDescription>

<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        <div class="row">
            <SfGrid DataSource="@GridData" Height="359">
                <GridColumns>
                    <GridColumn HeaderText="Image" Width="150">
                        <Template>
                            @{
                                var item = (context as EmployeeRecord)!;
                            }
                            <div class="image">
                                <img class="emp-avatar" src="@item.EmployeeImage" />
                            </div>
                        </Template>
                    </GridColumn>
                    <GridColumn Field=@nameof(EmployeeRecord.EmployeeID) HeaderText="Employee ID" Width="120" TextAlign="TextAlign.Center">
                        <Template>
                            @{
                                var item = (context as EmployeeRecord)!;
                            }
                            <a href="https://blazor.syncfusion.com/demos/" class="emp-id-link">@item.EmployeeID</a>
                        </Template>
                    </GridColumn>
                    <GridColumn Field=@nameof(EmployeeRecord.EmployeeName) HeaderText="Employee Name" Width="270">
                        <Template>
                            @{
                                var item = (context as EmployeeRecord)!;
                            }
                            <div class="emp-nameblock">
                                <span class="emp-name">@item.EmployeeName</span>
                                <span class="emp-email">@item.Email</span>
                            </div>
                        </Template>
                    </GridColumn>
                    <GridColumn Field=@nameof(EmployeeRecord.Department) HeaderText="Department" Width="180" />
                    <GridColumn Field=@nameof(EmployeeRecord.Role) HeaderText="Role" Width="220" />
                    <GridColumn Field=@nameof(EmployeeRecord.Team) HeaderText="Team" Width="180">
                        <Template>
                            @{
                                // Extract employee record from grid context
                                var record = context as EmployeeRecord;
                                // Select CSS class based on team value
                                var teamClass = record?.Team switch
                                {
                                            "Frontend" => "team-frontend",
                                            "Backend" => "team-backend",
                                            "DevOps" => "team-devops",
                                            "QA" => "team-qa",
                                            "Analytics" => "team-analytics",
                                            "Design" => "team-design",
                                            "Product" => "team-product",
                                    _ => "team-default"
                                };
                            }
                            <!-- Display team as styled badge -->
                            <span class="team-badge @teamClass">@record?.Team</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field=@nameof(EmployeeRecord.LastLoginAt) HeaderText="Last Login" Width="180" Format="dd-MMM-yyyy HH:mm" Type="ColumnType.DateTime" TextAlign="TextAlign.Right" />
                    <GridColumn Field=@nameof(EmployeeRecord.Shift) HeaderText="Shift" Width="160">
                        <Template>
                            @{
                                // Extract employee record from grid context
                                var record = context as EmployeeRecord;
                                // Select CSS class based on shift value
                                var shiftClass = record?.Shift switch
                                {
                                            "Regular Shift" => "shift-regular",
                                            "Night Shift" => "shift-night",
                                            "Rotational Shift" => "shift-rotational",
                                    _ => "shift-default"
                                };
                            }
                            <!-- Display shift as styled badge -->
                            <span class="shift-badge @shiftClass">@record?.Shift</span>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        </div>
    </div>
</div>

@code {

    public List<EmployeeRecord> GridData { get; private set; } = new();

    protected override void OnInitialized()
    {
        GridData = EmployeeData.GetAllRecords();
    }

}
@*Hidden:Lines*@
<style>
